# Smart-contract deployment environment template.
# This file is a reference only. Do not store secrets in this repository.
#
# Deployment scripts read environment files from the repository root:
# - Devnet:  DEVNET_ENV_FILE (default: ../.env)
# - Mainnet: MAINNET_ENV_FILE (default: ../.env.mainnet.local)

SOLANA_RPC_ENDPOINT=https://api.devnet.solana.com
SOLANA_NETWORK=devnet
SOLANA_PROGRAM_ID=BUzLPyNSfEGnKY3RozDtny4us72bYPbiCq2njQLjtaff

FEE_PAYER_KEYPAIR_PATH=/absolute/path/to/fee-payer-keypair.json
FEE_PAYER_PUBLIC_KEY=REPLACE_WITH_FEE_PAYER_PUBLIC_KEY

# Squads Vault 0 (program/admin authority target)
ADMIN_SQUADS_PUBLIC_KEY=REPLACE_WITH_SQUADS_VAULT_0_PUBLIC_KEY
# Squads Multisig Account (governance account, not program authority)
SQUADS_MULTISIG_PUBLIC_KEY=REPLACE_WITH_SQUADS_MULTISIG_PUBLIC_KEY

